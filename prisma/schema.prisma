// ---------- Generators & datasource ----------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------
enum PedidoEstado {
  PENDIENTE
  COMPLETADO
  ENTREGADO
  CANCELADO
}

enum PedidoCanceladoPor {
  USUARIO
  NEGOCIO
}

enum CompraEstado {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

enum PagoEstado {
  PENDIENTE
  PAGADO
  FALLIDO
}

enum MetodoPago {
  TARJETA
  BIZUM
  EFECTIVO
  STRIPE
  OTRO
}

/// Reserva para futuras reacciones. Hoy solo existe LIKE.
enum LikeTipo {
  LIKE
}

enum PostTipo {
  RESENA
  PROMOCION
  LOGRO
}

enum LogroTipo {
  COMPRA
  RESENA
  PROMOCION
  RESERVA
  OTRO
}

enum LogroCategoria {
  GENERAL
  EXPLORACION
  RESENAS
  COMPRAS
  RESERVAS
  PROMOCIONES
  NEGOCIO
  SOCIAL
  ESPECIAL
}

enum Dificultad {
  FACIL
  MEDIA
  DURA
  LEGENDARIA
}

enum MotivoTx {
  RESENA_AUTOR
  RESENA_NEGOCIO
  LIKE
  LOGRO
  RESERVA
  REFERIDO
  OTRO
}

enum RolNegocio {
  DUENO
  EMPLEADO
}

enum ContenidoEstado {
  BORRADOR
  PUBLICADO
  OCULTO
  REPORTADO
  ELIMINADO
}

enum TipoDescuento {
  PORCENTAJE
  IMPORTE_FIJO
  PACK
  DOS_X_UNO
}

enum ReservaEstado {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
  NO_SHOW
}

enum ReservaCanceladaPor {
  USUARIO
  NEGOCIO
}

enum EstadoCuenta {
  ACTIVA
  PENDIENTE_VERIFICACION
  SUSPENDIDA
  BLOQUEADA
  ELIMINADA
}

enum EstadoSolicitudProducto {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum RolGlobal {
  USUARIO
  MODERADOR
  ADMIN
}

/// Canal por el que se origina un pedido.
/// Clave para segmentar ventas en el dashboard por canal.
enum CanalVenta {
  WEB
  APP
  PRESENCIAL
  TELEFONO
  OTRO
}

enum NotificacionTipo {
  PROMOCION
  POST
  NEGOCIO
  RESENA
  RESERVA
  REFERIDO
  SISTEMA
}

enum ListaTipo {
  FAVORITOS
  COMPRA
  CURIOSOS
  PERSONALIZADA
}

// ---------- Modelos ----------
model Usuario {
  id                                   Int          @id @default(autoincrement())
  nombre                               String
  nickname                             String       @unique
  email                                String       @unique
  password                             String
  codigoReferido                       String?      @unique
  referidoPorId                        Int?
  foto                                 String?
  creadoEn                             DateTime     @default(now())
  actualizadoEn                        DateTime     @updatedAt
  eliminadoEn                          DateTime?
  biografia                            String?
  emailVerificado                      Boolean      @default(false)
  verificadoEn                         DateTime?
  codigoVerificacionEmailHash          String?
  codigoVerificacionEmailExpiraEn      DateTime?
  codigoVerificacionEmailIntentos      Int          @default(0)
  codigoVerificacionEmailUltimoEnvioEn DateTime?
  ultimoLoginEn                        DateTime?
  welcomeEmailSentAt                   DateTime?
  estadoCuenta                         EstadoCuenta @default(ACTIVA)
  rolGlobal                            RolGlobal    @default(USUARIO)

  // Economía de pétalos — separada conceptualmente del flujo transaccional real.
  // TODO: valorar mover PetaloTx a un schema/módulo propio para no contaminar queries de ventas.
  petalosSaldo Int        @default(0)
  petalosTx    PetaloTx[]

  // Relaciones
  referidoPor                 Usuario?                    @relation("UsuarioReferidos", fields: [referidoPorId], references: [id])
  referidos                   Usuario[]                   @relation("UsuarioReferidos")
  negocios                    Negocio[]                   @relation("DuenoNegocio")
  resenas                     Resena[]
  reservas                    Reserva[]
  pedidos                     Pedido[]
  compras                     Compra[]
  pagos                       Pago[]
  comentarios                 Comentario[]
  posts                       Post[]
  logrosUsuario               LogroUsuario[]
  logrosDestacados            UsuarioLogroDestacado[]
  likes                       Like[]
  negocioMiembros             NegocioMiembro[]
  siguiendo                   UsuarioSeguimiento[]        @relation("UsuarioSeguidor")
  seguidores                  UsuarioSeguimiento[]        @relation("UsuarioSeguido")
  siguiendoNegocios           NegocioSeguimiento[]
  visitasNegocio              VisitaNegocio[]
  solicitudesProductoCatalogo SolicitudProductoCatalogo[]
  notificaciones              Notificacion[]
  adminLogs                   AdminLog[]                  @relation("AdminLogsAdmin")
  productosFavoritos          ProductoFavorito[]
  listasCompra                ListaCompra[]
  listaCompraCodigos          ListaCompraCodigo[]

  @@index([estadoCuenta])
  @@index([rolGlobal])
  @@index([creadoEn])
  @@index([codigoReferido])
}

model Categoria {
  id            Int       @id @default(autoincrement())
  nombre        String    @unique
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  eliminadoEn   DateTime?

  negocios      Negocio[]
  subcategorias Subcategoria[]
  Logro         Logro[]

  @@index([activo])
}

model Subcategoria {
  id            Int       @id @default(autoincrement())
  nombre        String
  categoriaId   Int
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  eliminadoEn   DateTime?

  categoria Categoria @relation(fields: [categoriaId], references: [id])
  negocios  Negocio[]
  Logro     Logro[]

  @@unique([categoriaId, nombre])
  @@index([categoriaId])
  @@index([nombre])
  @@index([activo])
}

model Negocio {
  id               Int       @id @default(autoincrement())
  nombre           String
  slug             String?   @unique
  historia         String?
  descripcionCorta String?
  fechaFundacion   DateTime
  direccion        String?
  ciudad           String?
  codigoPostal     String?
  provincia        String?
  latitud          Decimal?  @db.Decimal(9, 6)
  longitud         Decimal?  @db.Decimal(9, 6)
  categoriaId      Int
  duenoId          Int
  fotoPerfil       String?
  fotoPortada      String?
  nenufarColor     String?   @map("nenufar_color")
  nenufarActivo    String?
  nenufarKey       String?
  nenufarAsset     String?
  telefono         String?
  emailContacto    String?
  web              String?
  instagram        String?
  verificado       Boolean   @default(false)
  activo           Boolean   @default(true)
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt
  eliminadoEn      DateTime?

  /// MVP: se mantiene en JSON para horario semanal y excepciones.
  /// TODO: si crecen las consultas/validaciones, normalizar a tablas HorarioNegocio/HorarioExcepcion.
  horario          Json?
  intervaloReserva Int?
  reservasActivas  Boolean @default(false)

  // Subcategoría opcional
  subcategoriaId Int?
  subcategoria   Subcategoria? @relation(fields: [subcategoriaId], references: [id])

  categoria Categoria @relation(fields: [categoriaId], references: [id])
  dueno     Usuario   @relation("DuenoNegocio", fields: [duenoId], references: [id])

  productos                   Producto[]
  promociones                 Promocion[]
  resenas                     Resena[]
  reservas                    Reserva[]
  logros                      Logro[]
  logrosNegocio               LogroNegocio[]
  posts                       Post[]
  pedidos                     Pedido[]
  compras                     Compra[]
  miembros                    NegocioMiembro[]
  seguidores                  NegocioSeguimiento[]
  visitasNegocio              VisitaNegocio[]
  recursos                    RecursoReserva[]
  solicitudesProductoCatalogo SolicitudProductoCatalogo[]
  notificaciones              Notificacion[]
  // TODO: para búsqueda geográfica real conviene un índice geoespacial manual en PostgreSQL/PostGIS.

  @@index([categoriaId])
  @@index([subcategoriaId])
  @@index([duenoId])
  @@index([slug])
  @@index([ciudad])
  @@index([activo])
  @@index([reservasActivas])
  @@index([verificado])
}

model Producto {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  /// TODO: validar en backend/SQL manual que precio >= 0.
  precio        Decimal?  @db.Decimal(10, 2)
  foto          String?
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  eliminadoEn   DateTime?
  negocioId     Int

  /// Código interno de producto (SKU). Útil para filtros y búsqueda en dashboard.
  codigoSKU      String?
  codigoProducto String? @unique

  /// Stock físico disponible para venta.
  /// TODO: validar en backend/SQL manual que stockDisponible >= 0.
  stockDisponible Int @default(0)

  /// Stock bloqueado por pedidos en curso, pendiente de confirmar o liberar.
  /// TODO: validar en backend/SQL manual que stockReservado >= 0 y <= stockDisponible + stockReservado.
  stockReservado Int @default(0)

  negocio            Negocio     @relation(fields: [negocioId], references: [id])
  promocionPrincipal Promocion[] @relation("ProductoPrincipal")
  promociones        Promocion[] @relation("PromocionPack")

  resenasProducto     ResenaProducto[]
  solicitudesCatalogo SolicitudProductoCatalogo[]
  pedidoProductos     PedidoProducto[]
  Logro               Logro[]
  favoritos           ProductoFavorito[]
  listaCompraItems    ListaCompraItem[]

  @@index([negocioId])
  @@index([activo])
  @@index([codigoSKU])
  @@index([codigoProducto])
}

model ProductoFavorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  productoId Int
  creadoEn   DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, productoId])
  @@index([productoId])
}

model ListaCompra {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  nombre        String    @default("Mi lista de la compra")
  tipo          ListaTipo @default(PERSONALIZADA)
  descripcion   String?
  color         String?
  iconoNenufar  String?
  creadaEn      DateTime  @default(now())
  actualizadaEn DateTime  @updatedAt
  eliminadaEn   DateTime?

  usuario Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  items   ListaCompraItem[]
  pedidos Pedido[]
  codigos ListaCompraCodigo[]

  @@unique([usuarioId, nombre])
  @@index([usuarioId])
  @@index([tipo])
}

model ListaCompraItem {
  id            Int      @id @default(autoincrement())
  listaCompraId Int
  productoId    Int?
  nombreManual  String?
  cantidad      Int      @default(1)
  completado    Boolean  @default(false)
  nota          String?
  creadoEn      DateTime @default(now())

  listaCompra ListaCompra @relation(fields: [listaCompraId], references: [id], onDelete: Cascade)
  producto    Producto?   @relation(fields: [productoId], references: [id], onDelete: SetNull)

  @@unique([listaCompraId, productoId])
  @@index([listaCompraId])
  @@index([productoId])
  @@index([completado])
}

/// Código corto para compartir/importar una Nenulista como copia independiente.
/// El snapshot queda fijado en el momento de generar el código: si el dueño
/// modifica su lista después, los códigos ya emitidos no cambian.
model ListaCompraCodigo {
  id              Int      @id @default(autoincrement())
  codigo          String   @unique
  listaCompraId   Int?
  usuarioOrigenId Int
  nombreSnapshot  String
  snapshot        Json
  creadoEn        DateTime @default(now())
  usadoVeces      Int      @default(0)
  activo          Boolean  @default(true)

  usuarioOrigen Usuario      @relation(fields: [usuarioOrigenId], references: [id], onDelete: Cascade)
  listaCompra   ListaCompra? @relation(fields: [listaCompraId], references: [id], onDelete: SetNull)

  @@index([codigo])
  @@index([usuarioOrigenId])
  @@index([activo])
}

model Post {
  id               Int             @id @default(autoincrement())
  usuarioId        Int
  tipo             PostTipo
  estado           ContenidoEstado @default(PUBLICADO)
  negocioId        Int?
  creadoEn         DateTime        @default(now())
  actualizadoEn    DateTime        @updatedAt
  moderadoEn       DateTime?
  motivoModeracion String?
  eliminadoEn      DateTime?

  /// Exactly one target must be present according to `tipo`.
  /// TODO: reforzar con CHECK SQL manual o validación de backend que exista exactamente una FK objetivo.
  resenaId    Int?
  promocionId Int?
  logroId     Int?

  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  negocio   Negocio?   @relation(fields: [negocioId], references: [id])
  resena    Resena?    @relation(fields: [resenaId], references: [id], onDelete: Cascade)
  promocion Promocion? @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  logro     Logro?     @relation(fields: [logroId], references: [id], onDelete: Cascade)

  comentarios    Comentario[]
  likes          Like[]
  notificaciones Notificacion[]

  @@index([creadoEn])
  @@index([tipo, creadoEn])
  @@index([usuarioId])
  @@index([negocioId])
  @@index([resenaId])
  @@index([promocionId])
  @@index([logroId])
  @@index([estado])
}

model Resena {
  id               Int             @id @default(autoincrement())
  contenido        String
  /// TODO: validar en backend o CHECK SQL manual que puntuacion esté entre 1 y 5.
  puntuacion       Int
  estado           ContenidoEstado @default(PUBLICADO)
  moderadoEn       DateTime?
  motivoModeracion String?
  selloNenufar     Boolean         @default(false)
  usuarioId        Int
  negocioId        Int
  creadoEn         DateTime        @default(now())
  actualizadoEn    DateTime        @updatedAt
  eliminadoEn      DateTime?

  negocio            Negocio                     @relation(fields: [negocioId], references: [id])
  usuario            Usuario                     @relation(fields: [usuarioId], references: [id])
  Post               Post[]
  productos          ResenaProducto[]
  productosSugeridos SolicitudProductoCatalogo[]
  // TODO: no se impone @@unique([usuarioId, negocioId]) para permitir histórico de reseñas.
  // Si se quiere una sola reseña activa por usuario y negocio, conviene hacerlo en backend o con índice único parcial SQL.

  @@index([negocioId, creadoEn])
  @@index([usuarioId])
  @@index([creadoEn])
  @@index([estado])
}

model ResenaProducto {
  id         Int      @id @default(autoincrement())
  resenaId   Int
  productoId Int
  creadoEn   DateTime @default(now())

  resena   Resena   @relation(fields: [resenaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([resenaId, productoId])
  @@index([resenaId])
  @@index([productoId])
}

model SolicitudProductoCatalogo {
  id             Int                     @id @default(autoincrement())
  negocioId      Int
  usuarioId      Int
  resenaId       Int?
  productoId     Int?
  nombre         String
  descripcion    String?
  precioSugerido Decimal?                @db.Decimal(10, 2)
  estado         EstadoSolicitudProducto @default(PENDIENTE)
  motivoRechazo  String?
  creadoEn       DateTime                @default(now())
  actualizadoEn  DateTime                @updatedAt

  negocio  Negocio   @relation(fields: [negocioId], references: [id])
  usuario  Usuario   @relation(fields: [usuarioId], references: [id])
  resena   Resena?   @relation(fields: [resenaId], references: [id], onDelete: SetNull)
  producto Producto? @relation(fields: [productoId], references: [id])

  @@index([negocioId, estado, creadoEn])
  @@index([usuarioId, creadoEn])
  @@index([resenaId])
  @@index([productoId])
}

model Promocion {
  id               Int             @id @default(autoincrement())
  titulo           String
  descripcion      String?
  negocioId        Int
  tipoDescuento    TipoDescuento   @default(PORCENTAJE)
  /// Se interpreta según `tipoDescuento`.
  /// - PORCENTAJE: 0-100
  /// - IMPORTE_FIJO: importe monetario
  /// - PACK / DOS_X_UNO: usar junto con backend para semántica exacta
  /// TODO: validar descuento según tipo y evitar valores negativos.
  descuento        Decimal         @db.Decimal(10, 2)
  fechaInicio      DateTime?
  fechaCaducidad   DateTime
  activa           Boolean         @default(true)
  estado           ContenidoEstado @default(PUBLICADO)
  moderadoEn       DateTime?
  motivoModeracion String?
  stockMaximo      Int?
  usosMaximos      Int?
  usosActuales     Int             @default(0)
  codigo           String?
  productoId       Int?
  creadoEn         DateTime        @default(now())
  actualizadoEn    DateTime        @updatedAt
  eliminadoEn      DateTime?

  negocio         Negocio          @relation(fields: [negocioId], references: [id])
  producto        Producto?        @relation("ProductoPrincipal", fields: [productoId], references: [id])
  pack            Producto[]       @relation("PromocionPack")
  Post            Post[]
  pedidoProductos PedidoProducto[]
  notificaciones  Notificacion[]

  @@index([negocioId])
  @@index([negocioId, fechaCaducidad])
  @@index([productoId])
  @@index([fechaCaducidad])
  @@index([codigo])
  @@index([estado])
  @@index([activa])
  @@index([activa, estado, fechaCaducidad])
}

model Logro {
  id               Int            @id @default(autoincrement())
  titulo           String
  descripcion      String?
  tipo             LogroTipo
  categoriaLogro   LogroCategoria @default(GENERAL)
  oculto           Boolean        @default(false)
  esFinal          Boolean        @default(false)
  accion           String?
  dificultad       Dificultad     @default(FACIL)
  /// TODO: validar en backend/SQL manual que umbral > 0.
  umbral           Int
  /// TODO: validar en backend/SQL manual que recompensaPuntos >= 0.
  recompensaPuntos Int
  creadoEn         DateTime       @default(now())
  actualizadoEn    DateTime       @updatedAt

  categoriaId    Int?
  subcategoriaId Int?
  negocioId      Int?
  productoId     Int?

  categoria    Categoria?    @relation(fields: [categoriaId], references: [id])
  subcategoria Subcategoria? @relation(fields: [subcategoriaId], references: [id])
  negocio      Negocio?      @relation(fields: [negocioId], references: [id])
  producto     Producto?     @relation(fields: [productoId], references: [id])

  logrosUsuario LogroUsuario[]
  logrosNegocio LogroNegocio[]
  destacadoPorUsuarios UsuarioLogroDestacado[]
  Post          Post[]

  @@index([categoriaId])
  @@index([subcategoriaId])
  @@index([negocioId])
  @@index([productoId])
  @@index([tipo])
  @@index([categoriaLogro])
  @@index([oculto])
  @@index([esFinal])
  @@index([accion])
}

model Pedido {
  id            Int          @id @default(autoincrement())
  negocioId     Int
  /// Usuario que origina el pedido. Opcional para pedidos presenciales anónimos.
  usuarioId     Int?
  estado        PedidoEstado @default(PENDIENTE)
  /// Canal por el que se originó el pedido. Clave para el dashboard de ventas por canal.
  canalVenta    CanalVenta   @default(WEB)
  /// Snapshot del importe total al cierre del pedido.
  /// Evita recalcular SUM(PedidoProducto.subtotal) en cada consulta del dashboard.
  /// TODO: validar en backend/SQL manual que totalSnapshot >= 0 cuando se informe.
  totalSnapshot Decimal?     @db.Decimal(10, 2)
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  motivoCancelacion String?
  canceladoEn       DateTime?
  canceladoPor      PedidoCanceladoPor?

  /// Lista de Mi Nenulista desde la que se cerró este pedido (si aplica).
  /// La lista puede seguir editándose después: este pedido no debe verse afectado,
  /// por eso se conserva `listaCompraSnapshot` con el estado exacto al cerrar.
  listaCompraId       Int?
  listaCompraSnapshot Json?

  negocio         Negocio          @relation(fields: [negocioId], references: [id])
  usuario         Usuario?         @relation(fields: [usuarioId], references: [id])
  listaCompra     ListaCompra?     @relation(fields: [listaCompraId], references: [id], onDelete: SetNull)
  pedidoProductos PedidoProducto[]
  compras         Compra[]

  @@index([negocioId])
  @@index([usuarioId])
  @@index([estado, creadoEn])
  @@index([canalVenta])
  @@index([listaCompraId])
}

model Compra {
  id            Int          @id @default(autoincrement())
  pedidoId      Int
  usuarioId     Int
  negocioId     Int
  /// Snapshot del total de la compra al materializarse.
  /// TODO: validar en backend/SQL manual que total >= 0.
  total         Decimal      @db.Decimal(10, 2)
  /// Código ISO 4217 de la moneda. Aunque hoy solo se use EUR, guardarlo evita migraciones futuras.
  moneda        String       @default("EUR")
  estado        CompraEstado @default(PENDIENTE)
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  /// Compra mantiene trazabilidad separada de Pedido y Pago para no perder histórico transaccional.
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  negocio Negocio @relation(fields: [negocioId], references: [id])
  pagos   Pago[]

  @@unique([pedidoId, usuarioId])
  @@index([pedidoId])
  @@index([usuarioId])
  @@index([negocioId])
  @@index([estado, creadoEn])
  @@index([moneda])
}

model Pago {
  id            Int        @id @default(autoincrement())
  compraId      Int
  usuarioId     Int
  metodoPago    MetodoPago
  estado        PagoEstado @default(PENDIENTE)
  /// TODO: validar en backend/SQL manual que cantidad >= 0.
  cantidad      Decimal    @db.Decimal(10, 2)
  /// Código ISO 4217 de la moneda. Debe coincidir con Compra.moneda.
  moneda        String     @default("EUR")
  /// ID de transacción externo (Stripe charge ID, referencia Bizum, etc.).
  /// Imprescindible para reconciliación financiera en el dashboard.
  refExterna    String?
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  /// Pago conserva cada intento o evento de cobro asociado a la compra.
  compra  Compra  @relation(fields: [compraId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([compraId])
  @@index([usuarioId])
  @@index([estado, creadoEn])
  @@index([refExterna])
}

/// Recurso reservable dentro de un negocio (mesa, sala, empleado, pista...).
/// Necesario para permitir múltiples reservas simultáneas en el mismo negocio.
model RecursoReserva {
  id            Int       @id @default(autoincrement())
  negocioId     Int
  nombre        String
  descripcion   String?
  capacidad     Int?
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  eliminadoEn   DateTime?

  negocio  Negocio   @relation(fields: [negocioId], references: [id])
  reservas Reserva[]

  @@index([negocioId])
  @@index([activo])
}

model Reserva {
  id                Int           @id @default(autoincrement())
  fecha             DateTime
  estado            ReservaEstado @default(PENDIENTE)
  usuarioId         Int
  negocioId         Int
  /// Recurso específico reservado (mesa, sala, empleado...).
  /// Permite múltiples reservas simultáneas en el mismo negocio.
  /// Si es null, el negocio no gestiona recursos diferenciados.
  recursoId         Int?
  nota              String?
  duracionMinutos   Int?
  numPersonas       Int?
  canceladaEn       DateTime?
  motivoCancelacion String?
  canceladaPor      ReservaCanceladaPor?
  creadoEn          DateTime      @default(now())
  actualizadoEn     DateTime      @updatedAt

  negocio Negocio         @relation(fields: [negocioId], references: [id])
  usuario Usuario         @relation(fields: [usuarioId], references: [id])
  recurso RecursoReserva? @relation(fields: [recursoId], references: [id])
  // TODO: validar en backend/SQL manual que duracionMinutos > 0 y numPersonas > 0 cuando se informen.
  // TODO: para negocios sin recursoId, validar solapamientos de rango (fecha, fecha+duracion) en backend.

  /// Unicidad por negocio + recurso + fecha. Si recursoId es null, el backend debe
  /// gestionar solapamientos de rango (fecha, fecha+duracion) para ese negocio.
  @@unique([negocioId, recursoId, fecha])
  @@index([negocioId])
  @@index([usuarioId])
  @@index([recursoId])
  @@index([fecha])
  @@index([estado])
}

model Comentario {
  id               Int             @id @default(autoincrement())
  contenido        String
  estado           ContenidoEstado @default(PUBLICADO)
  moderadoEn       DateTime?
  motivoModeracion String?
  usuarioId        Int
  postId           Int
  creadoEn         DateTime        @default(now())
  actualizadoEn    DateTime        @updatedAt
  eliminadoEn      DateTime?

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([usuarioId])
  @@index([estado])
}

model Like {
  id        Int      @id @default(autoincrement())
  tipo      LikeTipo @default(LIKE)
  usuarioId Int
  postId    Int
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, postId])
  @@index([postId])
}

model PedidoProducto {
  id                  Int      @id @default(autoincrement())
  pedidoId            Int
  productoId          Int
  promocionId         Int?
  /// TODO: validar en backend/SQL manual que cantidad > 0.
  cantidad            Int
  /// Snapshot del precio unitario aplicado en el momento del pedido.
  /// TODO: validar en backend/SQL manual que precioUnitario >= 0.
  precioUnitario      Decimal  @db.Decimal(10, 2)
  /// Descuento monetario aplicado sobre la línea en ese momento.
  /// TODO: validar en backend/SQL manual que descuentoAplicado >= 0 cuando exista.
  descuentoAplicado   Decimal? @db.Decimal(10, 2)
  /// TODO: validar en backend/SQL manual que subtotal >= 0 y sea coherente con cantidad/precio/descuento.
  subtotal            Decimal  @db.Decimal(10, 2)
  /// Snapshot de la categoría del producto en el momento del pedido.
  /// Permite filtrar ventas históricas por categoría sin depender de la categoría actual del producto.
  /// Si el producto cambia de categoría, el histórico de ventas sigue siendo correcto.
  categoriaIdSnapshot Int?
  creadoEn            DateTime @default(now())
  actualizadoEn       DateTime @updatedAt

  pedido            Pedido     @relation(fields: [pedidoId], references: [id])
  producto          Producto   @relation(fields: [productoId], references: [id])
  promocionAplicada Promocion? @relation(fields: [promocionId], references: [id])

  @@unique([pedidoId, productoId])
  @@index([pedidoId])
  @@index([productoId])
  @@index([promocionId])
  @@index([categoriaIdSnapshot])
}

model LogroUsuario {
  id            Int       @id @default(autoincrement())
  logroId       Int
  usuarioId     Int
  progreso      Int       @default(0)
  veces         Int       @default(0)
  conseguido    Boolean   @default(false)
  conseguidoEn  DateTime?
  actualizadoEn DateTime  @updatedAt

  logro   Logro   @relation(fields: [logroId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([logroId, usuarioId])
  @@index([usuarioId])
  @@index([conseguido])
}

model LogroNegocio {
  id            Int       @id @default(autoincrement())
  logroId       Int
  negocioId     Int
  progreso      Int       @default(0)
  veces         Int       @default(0)
  conseguido    Boolean   @default(false)
  conseguidoEn  DateTime?
  actualizadoEn DateTime  @updatedAt

  logro   Logro   @relation(fields: [logroId], references: [id], onDelete: Cascade)
  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([logroId, negocioId])
  @@index([negocioId])
  @@index([conseguido])
}

model UsuarioLogroDestacado {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  logroId       Int
  posicion      Int
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  logro   Logro   @relation(fields: [logroId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, posicion])
  @@unique([usuarioId, logroId])
  @@index([usuarioId])
}

model NegocioMiembro {
  id            Int        @id @default(autoincrement())
  negocioId     Int
  usuarioId     Int
  rol           RolNegocio @default(EMPLEADO)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  negocio Negocio @relation(fields: [negocioId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([negocioId, usuarioId])
  @@index([negocioId])
  @@index([usuarioId])
  @@index([rol])
}

/// Registro de visitas al perfil de un negocio.
/// Permite calcular tasa de conversión (visitas → compras/reservas) en el dashboard.
/// Tabla append-only: nunca se actualiza, solo se inserta.
model VisitaNegocio {
  id        Int      @id @default(autoincrement())
  negocioId Int
  /// Null si el visitante no está autenticado.
  usuarioId Int?
  /// Canal desde el que se realiza la visita (búsqueda, redes, directo...).
  origen    String?
  creadoEn  DateTime @default(now())

  negocio Negocio  @relation(fields: [negocioId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([negocioId, creadoEn])
  @@index([usuarioId])
  @@index([origen])
}

/// Transacciones del sistema de pétalos (economía de gamificación).
/// NOTA: separado conceptualmente del flujo transaccional real (Compra/Pago).
/// No mezclar en queries de ventas ni reportes financieros.
model PetaloTx {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  delta           Int
  /// Saldo resultante tras la transacción. Obligatorio para auditoría del saldo.
  saldoResultante Int
  motivo          MotivoTx
  descripcion     String?
  metadata        Json?
  /// Referencia polimórfica flexible para trazabilidad.
  /// TODO: `refTipo` + `refId` no garantizan integridad referencial fuerte; validarlo en backend si hace falta.
  refTipo         String?
  refId           Int?
  creadoEn        DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, creadoEn])
  @@index([usuarioId, motivo, creadoEn])
  @@index([refTipo, refId])
}

model Notificacion {
  id          Int              @id @default(autoincrement())
  usuarioId   Int
  tipo        NotificacionTipo
  titulo      String
  contenido   String?
  link        String?
  leida       Boolean          @default(false)
  creadoEn    DateTime         @default(now())
  leidaEn     DateTime?
  negocioId   Int?
  promocionId Int?
  postId      Int?

  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  negocio   Negocio?   @relation(fields: [negocioId], references: [id], onDelete: SetNull)
  promocion Promocion? @relation(fields: [promocionId], references: [id], onDelete: SetNull)
  post      Post?      @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([usuarioId, leida])
  @@index([usuarioId, creadoEn])
  @@index([negocioId])
  @@index([postId])
  @@index([promocionId])
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  accion    String
  entidad   String
  entidadId Int?
  motivo    String?
  creadoEn  DateTime @default(now())

  admin Usuario @relation("AdminLogsAdmin", fields: [adminId], references: [id])

  @@index([adminId, creadoEn])
  @@index([entidad, entidadId])
  @@index([accion, creadoEn])
}

model UsuarioSeguimiento {
  id         Int      @id @default(autoincrement())
  seguidorId Int
  seguidoId  Int
  creadoEn   DateTime @default(now())

  seguidor Usuario @relation("UsuarioSeguidor", fields: [seguidorId], references: [id])
  seguido  Usuario @relation("UsuarioSeguido", fields: [seguidoId], references: [id])
  // TODO: impedir auto-follow (`seguidorId != seguidoId`) en backend o con CHECK SQL manual.

  @@unique([seguidorId, seguidoId])
  @@index([seguidorId])
  @@index([seguidoId])
}

model NegocioSeguimiento {
  id                    Int      @id @default(autoincrement())
  usuarioId             Int
  negocioId             Int
  creadoEn              DateTime @default(now())
  notificacionesActivas Boolean  @default(true)

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  negocio Negocio @relation(fields: [negocioId], references: [id])

  @@unique([usuarioId, negocioId])
  @@index([usuarioId])
  @@index([negocioId])
}

model CodigoNenufarizacion {
  id       Int       @id @default(autoincrement())
  codigo   String    @unique
  usado    Boolean   @default(false)
  activo   Boolean   @default(true)
  creadoEn DateTime  @default(now())
  usadoEn  DateTime?

  @@index([activo, usado])
}
